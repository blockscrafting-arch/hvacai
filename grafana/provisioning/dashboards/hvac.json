          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  created_at AS \"Время\",\n  status AS \"Статус\",\n  COALESCE(ai_response->>'alert_level', '') AS \"Уровень\",\n  COALESCE(ai_response->>'problem', '') AS \"Проблема\",\n  COALESCE(ai_response->>'message', '') AS \"Сообщение\"\nFROM ai_decisions\nWHERE $__timeFilter(created_at)\nORDER BY created_at DESC\nLIMIT 200",
          "refId": "A"
        }
      ],
      "title": "Последние решения AI (ai_decisions)",
      "type": "table"
