# Скопируйте: cp .env.example .env
# Обязательно замените пароли, ключ и публичные URL (не 127.0.0.1 для заказчика).
#
# Caddy (см. caddy/Caddyfile): A-записи на IP сервера, UFW allow 80,443/tcp (и опц. 443/udp).
# n8n и Grafana не пробрасывают порты наружу — только https://домен

# --- PostgreSQL / TimescaleDB ---
POSTGRES_USER=postgres
POSTGRES_DB=hvac
POSTGRES_PASSWORD=change_me_strong_password

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana
# Публичный корень Grafana (за Caddy — https):
GRAFANA_ROOT_URL=https://grafana.petushkevich.ru/

# --- n8n ---
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https
# Публичный URL n8n (за Caddy, со слэшем в конце):
N8N_PUBLIC_URL=https://n8n.petushkevich.ru/
# Количество reverse proxy перед n8n (Caddy = 1)
N8N_PROXY_HOPS=1
# Ключ шифрования credentials (обязателен): openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# Доступ к $env в workflow (Telegram chatId, GRAFANA_URL): в docker-compose задано
# N8N_BLOCK_ENV_ACCESS_IN_NODE=false. Мультитенант — можно вручную true и убрать $env из нод.

# Ссылка в Telegram — публичный Grafana + путь дашборда (UID hvac после создания панели)
GRAFANA_URL=https://grafana.petushkevich.ru/d/hvac

# --- Часовой пояс ---
TZ=Europe/Moscow
GENERIC_TIMEZONE=Europe/Moscow

# --- Опционально (workflow: $env.TELEGRAM_CHAT_ID) ---
# TELEGRAM_CHAT_ID=
