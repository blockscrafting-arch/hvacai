# Скопируйте: cp .env.example .env
# Обязательно замените пароли, ключ и публичные URL (IP/домен сервера, не 127.0.0.1 для заказчика).

# --- PostgreSQL / TimescaleDB ---
POSTGRES_USER=postgres
POSTGRES_DB=hvac
POSTGRES_PASSWORD=change_me_strong_password

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana
# Публичный корень Grafana (тот же хост, что открываете в браузере):
GRAFANA_ROOT_URL=http://127.0.0.1:3000/

# --- n8n ---
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
# Публичный URL n8n (IP или домен сервера, не localhost с телефона заказчика):
N8N_PUBLIC_URL=http://127.0.0.1:5678/
# Ключ шифрования credentials (обязателен): openssl rand -hex 32
N8N_ENCRYPTION_KEY=

# Ссылка на дашборд в Telegram — тот же хост, что и Grafana + путь панели (UID /d/hvac задайте после создания дашборда)
# Пример для VPS: http://203.0.113.10:3000/d/hvac
GRAFANA_URL=http://127.0.0.1:3000/d/hvac

# --- Часовой пояс ---
TZ=Europe/Moscow
GENERIC_TIMEZONE=Europe/Moscow

# --- Опционально (workflow: $env.TELEGRAM_CHAT_ID) ---
# TELEGRAM_CHAT_ID=
